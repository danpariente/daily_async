<div style="background:var(--surface);border:1px solid <%= daily.blocked ? 'rgba(245,66,75,.5)' : 'var(--line)' %>;border-radius:10px;padding:16px 18px;margin-bottom:16px">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
    <span style="font-family:'IBM Plex Mono';font-weight:600;color:var(--accent)"><%= daily.dev_name %></span>
    <% if daily.blocked %>
      <span style="font-family:'IBM Plex Mono';font-size:11px;font-weight:600;color:#fff;background:#f5424b;border-radius:6px;padding:2px 8px;letter-spacing:.04em">🚩 BLOQUEADO</span>
    <% end %>
  </div>
  <% if daily.blocked && daily.blocker_note.present? %>
    <div style="font-size:13px;color:#ffb3b8;background:rgba(245,66,75,.08);border-left:2px solid #f5424b;border-radius:4px;padding:7px 10px;margin-bottom:12px"><%= daily.blocker_note %></div>
  <% end %>
  <% daily.clips.each do |clip| %>
    <div style="margin-bottom:14px">
      <div style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);margin-bottom:6px">
        <%= clip.kind %> · <%= "%d:%02d" % [clip.duration_seconds/60, clip.duration_seconds%60] %>
      </div>
      <% if clip.file.attached? %>
        <video controls playsinline preload="metadata"
               src="<%= rails_blob_path(clip.file, disposition: 'inline') %>"
               style="width:100%;max-width:520px;border-radius:8px;background:#000"></video>
      <% end %>
      <% if clip.marks.present? %>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px">
          <% clip.marks.each do |m| %>
            <span style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);border:1px solid var(--line);border-radius:6px;padding:3px 8px">
              <%= "%d:%02d" % [m['t'].to_i/60, m['t'].to_i%60] %> · <%= m['label'] %>
            </span>
          <% end %>
        </div>
      <% end %>
      <% case clip.transcript_status %>
      <% when "done" %>
        <details style="margin-top:8px" open>
          <summary style="font-family:'IBM Plex Mono';font-size:11px;color:var(--accent);cursor:pointer">transcripción</summary>
          <p style="font-size:14px;color:var(--txt);margin-top:6px;white-space:pre-wrap;line-height:1.55"><%= clip.transcript.presence || "(sin audio reconocible)" %></p>
        </details>
      <% when "failed" %>
        <div style="font-family:'IBM Plex Mono';font-size:11px;color:#f5a623;margin-top:8px">⚠️ no se pudo transcribir</div>
      <% else %>
        <div style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);margin-top:8px">⏳ transcribiendo…</div>
      <% end %>
    </div>
  <% end %>
</div>
