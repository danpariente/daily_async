<div style="background:var(--surface);border:1px solid <%= daily.blocked ? 'rgba(245,66,75,.5)' : 'var(--line)' %>;border-radius:10px;padding:16px 18px;margin-bottom:16px">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
    <span style="font-family:'IBM Plex Mono';font-weight:600;color:var(--accent)"><%= daily.dev_name %></span>
    <% if daily.blocked %>
      <span style="font-family:'IBM Plex Mono';font-size:11px;font-weight:600;color:#fff;background:#f5424b;border-radius:6px;padding:2px 8px;letter-spacing:.04em">🚩 BLOQUEADO</span>
    <% end %>
  </div>
  <% if daily.blocked && daily.blocker_note.present? %>
    <div style="font-size:13px;color:#ffb3b8;background:rgba(245,66,75,.08);border-left:2px solid #f5424b;border-radius:4px;padding:7px 10px;margin-bottom:14px"><%= daily.blocker_note %></div>
  <% end %>

  <%# Transcripción verbatim limpia, separada por pregunta %>
  <% if daily.analysis_done? && daily.segments? %>
    <div style="margin-bottom:14px">
      <% [["Ayer", "ayer"], ["Hoy", "hoy"], ["Bloqueos", "bloqueos"]].each do |label, key| %>
        <% seek = daily.seek_for(key) %>
        <div style="margin-bottom:9px">
          <% if seek %>
            <div data-seek="<%= seek[0] %>" data-t="<%= seek[1] %>" title="Saltar el video a esta pregunta" style="display:inline-flex;align-items:center;gap:5px;font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px">▶ <%= label %> <span style="opacity:.6;text-transform:none"><%= "%d:%02d" % [seek[1] / 60, seek[1] % 60] %></span></div>
          <% else %>
            <div style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px"><%= label %></div>
          <% end %>
          <% if daily.segment(key).present? %>
            <div style="font-size:14px;color:var(--txt);line-height:1.55"><%= daily.segment(key) %></div>
          <% else %>
            <div style="font-size:14px;color:var(--muted);opacity:.6">—</div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% elsif daily.analysis_done? %>
    <div style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);margin-bottom:12px">(sin audio reconocible)</div>
  <% elsif daily.analysis_failed? %>
    <div style="font-family:'IBM Plex Mono';font-size:11px;color:#f5a623;margin-bottom:12px">⚠️ no se pudo procesar el daily</div>
  <% else %>
    <div style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);margin-bottom:12px">⏳ procesando transcripción…</div>
  <% end %>

  <%# Clips: reproductores + marcas %>
  <% daily.clips.each do |clip| %>
    <div style="margin-bottom:14px">
      <div style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);margin-bottom:6px">
        <%= clip.kind %> · <%= "%d:%02d" % [clip.duration_seconds/60, clip.duration_seconds%60] %>
      </div>
      <% if clip.file.attached? %>
        <video id="clip-video-<%= clip.id %>" controls playsinline preload="metadata"
               src="<%= rails_blob_path(clip.file, disposition: 'inline') %>"
               style="width:100%;max-width:520px;border-radius:8px;background:#000"></video>
      <% end %>
      <% if clip.marks.present? %>
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:6px">
          <% clip.marks.each do |m| %>
            <span data-seek="<%= clip.id %>" data-t="<%= m['t'].to_i %>" title="Saltar el video aquí" style="font-family:'IBM Plex Mono';font-size:11px;color:var(--muted);border:1px solid var(--line);border-radius:6px;padding:3px 8px">
              ▶ <%= "%d:%02d" % [m['t'].to_i/60, m['t'].to_i%60] %> · <%= m['label'] %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
