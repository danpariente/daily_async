<% dow = %w[domingo lunes martes miércoles jueves viernes sábado][@date.wday] %>
<div style="display:flex;align-items:baseline;gap:12px;border-bottom:1px solid var(--line);padding-bottom:14px;margin-bottom:18px">
  <h1>ASYNC DAILY · <%= @date.iso8601 %></h1>
  <span style="font-family:'IBM Plex Mono';color:var(--muted);font-size:13px"><%= dow %></span>
  <span style="flex:1"></span>
  <%= link_to "últimos 5 días", week_dailies_path, style: "font-family:'IBM Plex Mono';font-size:12px" %>
  <span style="color:var(--muted)">·</span>
  <%= link_to "‹ día anterior", dailies_path(date: (@date - 1).iso8601), style: "font-family:'IBM Plex Mono';font-size:12px" %>
  <%= link_to "día siguiente ›", dailies_path(date: (@date + 1).iso8601), style: "font-family:'IBM Plex Mono';font-size:12px" %>
</div>

<% if @dailies.empty? %>
  <p style="color:var(--muted)">Nadie ha enviado su daily para esta fecha todavía.</p>
<% end %>

<%= render @dailies %>
